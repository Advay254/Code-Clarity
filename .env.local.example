# Copy this file to .env.local and fill in your values
# In Vercel, add these as Environment Variables in your project settings

# Your Directus instance URL (your Render deployment)
NEXT_PUBLIC_DIRECTUS_URL=https://your-directus-service.onrender.com

# Directus static token for reading published posts
# Generate this in Directus → Settings → Access Tokens
DIRECTUS_TOKEN=your_directus_static_token_here

# Your blog's public URL (your Vercel deployment)
NEXT_PUBLIC_SITE_URL=https://your-blog.vercel.app

# Blog metadata
NEXT_PUBLIC_BLOG_NAME=My Blog
NEXT_PUBLIC_BLOG_DESCRIPTION=Thoughts, stories and ideas.

# Google AdSense publisher ID (get this from Google AdSense after approval)
# Format: ca-pub-XXXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Secret for on-demand revalidation (generate with: openssl rand -hex 32)
REVALIDATE_SECRET=your_revalidation_secret_here
